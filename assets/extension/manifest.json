{
  "manifest_version": 3,
  "name": "derStandard Comment Ranker Mobile",
  "version": "1.9.10",
  "description": "Mobile-kompatible inoffizielle Firefox-Extension zum Sortieren von Kommentaren auf derstandard.at/.de nach Bewertungen. Unabhaengig entwickelt.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.derstandard.at/*",
    "*://*.derstandard.de/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.derstandard.at/*",
        "*://*.derstandard.de/*"
      ],
      "js": [
        "content.js",
        "rating.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "derstandard-ranker-mobile@example.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "113.0"
    }
  }
}
